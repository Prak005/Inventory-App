<html>
    <head>
        <title><%= title %></title>
    </head>
    <body>
        <h1><%= title%></h1>
        <h2>Categories</h2>
        <ul>
            <% categories.forEach(category => { %>
                <li>
                    <a href="/category/<%= category.id %>">
                        <%= category.name %>
                    </a>
                </li>
            <% }) %>
        </ul>
    </body>
</html>